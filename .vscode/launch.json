{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "chrome",
            "request": "launch",
            "name": "NuxtAuth: Chrome",
            "url": "http://localhost:3000",
            "webRoot": "${workspaceFolder}",
            "presentation": {
                "hidden": false,
                "group": "Nuxt",
                "order": 1
            }
        },
        {
            "type": "node",
            "request": "launch",
            "name": "NuxtAuth: Server",
            "outputCapture": "std",
            "program": "${workspaceFolder}/node_modules/nuxt/bin/nuxt.mjs",
            "envFile": "${workspaceFolder}/.env",
            "presentation": {
                "hidden": false,
                "group": "Nuxt",
                "order": 1
            },
            "args": [
                "dev"
            ]
        }
    ],
    "compounds": [
        {
            "name": "NuxtAuth Fullstack: Nuxt",
            "presentation": {
                "hidden": false,
                "group": "Nuxt",
                "order": 1
            },
            "configurations": [
                "NuxtAuth: Server",
                "NuxtAuth: Chrome"
            ]
        }
    ]
}
